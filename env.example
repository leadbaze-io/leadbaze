# LeadBaze Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# N8N Webhook
VITE_N8N_WEBHOOK_URL=https://seu-n8n.com/webhook

# App Configuration
VITE_APP_ENV=production
VITE_DEBUG_MODE=false

# Evolution API (Optional)
VITE_EVOLUTION_API_URL=https://sua-evolution-api.com
VITE_EVOLUTION_API_KEY=sua_chave_api
VITE_EVOLUTION_INSTANCE_NAME=leadbaze-instance
